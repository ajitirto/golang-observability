{
  "title": "HOME - Observability",
  "uid": "home-observability",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests Total",
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (path)",
          "legendFormat": "{{path}}"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Duration (99th percentile)",
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, path))",
          "legendFormat": "{{path}}"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "logs",
      "title": "Application Logs",
      "datasource": { "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"go-app\"}"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 }
    }
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s"
}
